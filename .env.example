# Supabase Configuration
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-supabase-service-role-or-anon-key

# Database Connection URL (required only for running local database setup scripts)
# Format: postgresql://postgres:[your-password]@db.[your-project-id].supabase.co:5432/postgres
SUPABASE_DB_URL=

# Groq / OpenAI Configuration
# You can define a single key using OPENAI_API_KEY, or multiple comma-separated keys 
# using OPENAI_API_KEYS to enable automatic round-robin key rotation (useful for rate limits on Groq).
OPENAI_API_KEY=gsk_your-single-groq-api-key
OPENAI_API_KEYS=gsk_key1,gsk_key2,gsk_key3

# Testing & Cost Optimization Flags
ENABLE_LLM_FALLBACK=True
ENABLE_RETRIEVAL_ONLY_MODE=True
